rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user owns the document
    function isOwner(resource) {
      return request.auth != null
        && request.auth.uid in resource.data.users;
    }

    // Helper: check if the incoming write sets the current user as an owner
    function isWritingAsOwner() {
      return request.auth != null
        && request.auth.uid in request.resource.data.users;
    }

    match /tasks/{taskId} {
      allow read, update, delete: if isOwner(resource);
      allow create: if isWritingAsOwner();
    }

    match /clients/{clientId} {
      allow read, update, delete: if isOwner(resource);
      allow create: if isWritingAsOwner();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
